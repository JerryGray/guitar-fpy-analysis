  <DataSources>
    <DataSource Name="DataSource1">
      <rd:SecurityType>Integrated</rd:SecurityType>
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=localhost;Initial Catalog=GraywolfeQuality</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:DataSourceID>e35e8c86-f524-4ec2-a99c-397129eef015</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="ProductionUnits">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT
    pu.unit_id,
    gm.model_name,
    gm.model_line,
    gm.model_family,
    pu.batch_id,
    pu.start_date,
    pu.finish_name,
    pu.final_status,
    CAST(DATEDIFF(MINUTE, pu.woodworking_start_ts, pu.final_qc_end_ts) / 60.0 / 24.0
         AS DECIMAL(6,1)) AS total_production_days,
    pu.final_qc_end_ts
FROM
    production_units pu
    JOIN guitar_models gm ON pu.model_id = gm.model_id
ORDER BY
    pu.start_date, gm.model_name</CommandText>
      </Query>
      <Fields>
        <Field Name="unit_id">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>unit_id</DataField>
        </Field>
        <Field Name="model_name">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>model_name</DataField>
        </Field>
        <Field Name="model_line">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>model_line</DataField>
        </Field>
        <Field Name="model_family">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>model_family</DataField>
        </Field>
        <Field Name="batch_id">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>batch_id</DataField>
        </Field>
        <Field Name="start_date">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>start_date</DataField>
        </Field>
        <Field Name="finish_name">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>finish_name</DataField>
        </Field>
        <Field Name="final_status">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>final_status</DataField>
        </Field>
        <Field Name="total_production_days">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>total_production_days</DataField>
        </Field>
        <Field Name="final_qc_end_ts">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>final_qc_end_ts</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>

  <DataSources>
    <DataSource Name="DataSource1">
      <rd:SecurityType>Integrated</rd:SecurityType>
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=localhost;Initial Catalog=GraywolfeQuality</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:DataSourceID>d9bf866b-9a1e-484b-a0f1-deebe18bcc20</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@StartDate">
            <Value>=Parameters!StartDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@EndDate">
            <Value>=Parameters!EndDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Stage">
            <Value>=Parameters!Stage.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT
    qi.inspection_date,
    gm.model_name,
    gm.model_line,
    pu.finish_name,
    qi.stage,
    w.name          AS inspector_name,
    qi.pass_first_time,
    qi.rework_required,
    qi.scrapped_at_stage,
    dt.defect_name,
    dt.severity,
    rc.description  AS root_cause,
    rc.scope        AS root_cause_scope,
    s.supplier_name,
    s.tier          AS supplier_tier
FROM
    quality_inspections qi
    JOIN production_units pu  ON qi.unit_id       = pu.unit_id
    JOIN guitar_models gm     ON pu.model_id      = gm.model_id
    JOIN workers w            ON qi.inspector_id  = w.worker_id
    LEFT JOIN defect_types dt ON qi.defect_id     = dt.defect_id
    LEFT JOIN root_causes rc  ON qi.root_cause_id = rc.root_cause_id
    LEFT JOIN suppliers s     ON qi.supplier_id   = s.supplier_id
WHERE
    qi.inspection_date &gt;= @StartDate
    AND qi.inspection_date &lt; DATEADD(DAY, 1, @EndDate)
    AND (@Stage = 'All' OR qi.stage = @Stage)
ORDER BY
    qi.inspection_date, gm.model_name</CommandText>
      </Query>
      <Fields>
        <Field Name="inspection_date">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>inspection_date</DataField>
        </Field>
        <Field Name="model_name">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>model_name</DataField>
        </Field>
        <Field Name="model_line">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>model_line</DataField>
        </Field>
        <Field Name="finish_name">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>finish_name</DataField>
        </Field>
        <Field Name="stage">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>stage</DataField>
        </Field>
        <Field Name="inspector_name">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>inspector_name</DataField>
        </Field>
        <Field Name="pass_first_time">
          <rd:TypeName>System.Boolean</rd:TypeName>
          <DataField>pass_first_time</DataField>
        </Field>
        <Field Name="rework_required">
          <rd:TypeName>System.Boolean</rd:TypeName>
          <DataField>rework_required</DataField>
        </Field>
        <Field Name="scrapped_at_stage">
          <rd:TypeName>System.Boolean</rd:TypeName>
          <DataField>scrapped_at_stage</DataField>
        </Field>
        <Field Name="defect_name">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>defect_name</DataField>
        </Field>
        <Field Name="severity">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>severity</DataField>
        </Field>
        <Field Name="root_cause">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>root_cause</DataField>
        </Field>
        <Field Name="root_cause_scope">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>root_cause_scope</DataField>
        </Field>
        <Field Name="supplier_name">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>supplier_name</DataField>
        </Field>
        <Field Name="supplier_tier">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>supplier_tier</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="MaxInspectionDate">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT CAST(MAX(inspection_date) AS DATE) AS max_date
FROM quality_inspections</CommandText>
      </Query>
      <Fields>
        <Field Name="max_date">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>max_date</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="MinInspectionDate">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT CAST(MIN(inspection_date) AS DATE) AS min_date
FROM quality_inspections</CommandText>
      </Query>
      <Fields>
        <Field Name="min_date">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>min_date</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>

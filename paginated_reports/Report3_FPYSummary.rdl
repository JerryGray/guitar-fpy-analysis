    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="FPYSummary">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>WITH unit_fpy AS (
    SELECT
        unit_id,
        CASE WHEN SUM(CASE WHEN pass_first_time = 0 THEN 1 ELSE 0 END) = 0
             THEN 1 ELSE 0 END AS passed_fpy
    FROM quality_inspections
    GROUP BY unit_id
),
unit_metrics AS (
    SELECT
        pu.unit_id,
        pu.model_id,
        pu.start_date,
        uf.passed_fpy,
        CASE WHEN pu.final_status = 'Reworked' THEN 1 ELSE 0 END AS unit_reworks,
        SUM(CASE WHEN qi.scrapped_at_stage = 1  THEN 1 ELSE 0 END) AS unit_scrapped,
        COUNT(qi.inspection_id)                                     AS unit_inspections,
        SUM(CASE WHEN qi.pass_first_time = 0    THEN 1 ELSE 0 END) AS unit_failures
    FROM production_units pu
    JOIN quality_inspections qi ON qi.unit_id = pu.unit_id
    JOIN unit_fpy uf            ON uf.unit_id = pu.unit_id
    GROUP BY
        pu.unit_id,
        pu.model_id,
        pu.start_date,
        pu.final_status,
        uf.passed_fpy
)
SELECT
    gm.model_name,
    gm.model_line,
    gm.model_family,
    YEAR(um.start_date)             AS inspection_year,
    MONTH(um.start_date)            AS inspection_month,
    DATENAME(MONTH, um.start_date)  AS month_name,
    COUNT(um.unit_id)               AS units_inspected,
    SUM(um.passed_fpy)              AS units_passed_fpy,
    SUM(um.unit_reworks)            AS total_reworks,
    SUM(um.unit_scrapped)           AS total_scrapped,
    SUM(um.unit_inspections)        AS total_inspections,
    SUM(um.unit_failures)           AS total_failures,
    gm.target_yield
FROM unit_metrics um
JOIN guitar_models gm ON gm.model_id = um.model_id
GROUP BY
    gm.model_name,
    gm.model_line,
    gm.model_family,
    YEAR(um.start_date),
    MONTH(um.start_date),
    DATENAME(MONTH, um.start_date),
    gm.target_yield
ORDER BY
    gm.model_name,
    inspection_year,
    inspection_month</CommandText>
      </Query>
      <Fields>
        <Field Name="model_name">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>model_name</DataField>
        </Field>
        <Field Name="model_line">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>model_line</DataField>
        </Field>
        <Field Name="model_family">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>model_family</DataField>
        </Field>
        <Field Name="inspection_year">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>inspection_year</DataField>
        </Field>
        <Field Name="inspection_month">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>inspection_month</DataField>
        </Field>
        <Field Name="month_name">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>month_name</DataField>
        </Field>
        <Field Name="units_inspected">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>units_inspected</DataField>
        </Field>
        <Field Name="units_passed_fpy">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>units_passed_fpy</DataField>
        </Field>
        <Field Name="total_reworks">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>total_reworks</DataField>
        </Field>
        <Field Name="total_scrapped">
